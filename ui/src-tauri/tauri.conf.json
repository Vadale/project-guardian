{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guardian",
  "version": "0.0.0",
  "identifier": "ai.guardian.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Guardian — Approvals",
        "width": 760,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "AI guardian firewall — approvals cockpit",
    "longDescription": "Guardian mediates an autonomous AI agent's actions against a deterministic policy and surfaces approvals. This is the desktop cockpit.",
    "copyright": "Apache-2.0, Project Guardian contributors"
  }
}
